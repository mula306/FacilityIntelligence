{
  "name": "@facility/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run db:generate && tsc -p tsconfig.json",
    "db:prepare-sqlite": "dotenv -e ../../.env -- tsx src/ensure-sqlite.ts",
    "db:generate": "dotenv -e ../../.env -- prisma generate --schema prisma/schema.prisma",
    "db:migrate": "npm run db:prepare-sqlite && dotenv -e ../../.env -- prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.17.1"
  }
}
